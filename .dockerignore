# Keep the build context small. chroma_db/ (root) IS included on purpose.
# Only data/raw/ (227MB filings) is excluded; data/processed/chunks.json IS
# needed at runtime by the TF-IDF retriever (retrieve_tfidf.py).
data/raw/
venv/
.venv/
# secrets never go in the image; GEMINI_API_KEY is passed as an env var at deploy time
.env
.git/
__pycache__/
**/__pycache__/
*.pyc
*.pdf
.DS_Store
